# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=PathOS
APP_ENV=development          # development | staging | production
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pathos:pathos_pass@localhost:5432/pathos_db
DATABASE_URL_SYNC=postgresql://pathos:pathos_pass@localhost:5432/pathos_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=pathos-documents-prod
S3_BUCKET_DEIDENTIFIED=pathos-deidentified-dev

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://pathos.yourdomain.com"]

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_OCR=true
ENABLE_PHI_DETECTION=true
ENABLE_AUTO_TAGGING=true
ENABLE_AUDIT_ALERTS=true
MAX_FILE_SIZE_MB=50
